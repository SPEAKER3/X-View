flowchart LR
    %% Актори
    User((🧍 Зареєстрований <br> користувач))
    Admin((🛠 Адміністратор))

    %% Межа системи
    subgraph XView [Система X-View]
        direction TB
        UC1([Авторизація в системі])
        UC2([Завантаження документа])
        UC_Ext([Повідомлення про помилку 'Файл завеликий'])
        UC3([Екстракція даних за промптом])
        UC_Inc([Взаємодія з LLM API])
        UC4([Експорт результатів])
        UC5([Перегляд історії запитів])
        UC6([Моніторинг системи та керування лімітами])
    end

    %% Зв'язки актор-прецедент
    User --- UC1
    User --- UC2
    User --- UC3
    User --- UC4
    User --- UC5

    Admin --- UC1
    Admin --- UC6

    %% Зв'язки include та extend (пунктирні лінії зі стрілками)
    UC_Ext -. "<<extend>>\n(якщо розмір > 50 МБ)" .-> UC2
    UC3 -. "<<include>>" .-> UC_Inc